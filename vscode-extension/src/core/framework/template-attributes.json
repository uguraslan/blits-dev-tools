  "fit": {
    "attrType": "regular",
    "types": [
      "enum",
      {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "cover",
              "contain"
            ]
          },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        }
      }
    ],
    "values": [
      "cover",
      "contain"
